# Copy to .env and adjust. All variables are optional — defaults are sensible.

# Symbols (comma-separated). Each exchange uses its native convention.
MDC_BINANCE_SYMBOLS=btcusdt,ethusdt
MDC_COINBASE_SYMBOLS=BTC-USD,ETH-USD
MDC_KRAKEN_SYMBOLS=XBT/USD,ETH/USD

# Kafka
MDC_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MDC_KAFKA_TOPIC=market.ticks
MDC_KAFKA_CLIENT_ID=market-data-collector
MDC_KAFKA_LINGER_MS=5
MDC_KAFKA_COMPRESSION=lz4
MDC_KAFKA_ACKS=1

# Bounded queue between WS adapters and Kafka producer (backpressure isolation).
MDC_QUEUE_MAX_SIZE=10000

# Metrics (Prometheus exposition)
MDC_METRICS_ENABLED=true
MDC_METRICS_PORT=9100

# Backoff
MDC_BACKOFF_INITIAL_SECONDS=1.0
MDC_BACKOFF_MAX_SECONDS=60.0
MDC_BACKOFF_MULTIPLIER=2.0

# Misc
MDC_LOG_LEVEL=INFO
MDC_METRICS_LOG_INTERVAL_SECONDS=30
